  if(sol==='pending'){
    sa.innerHTML='<div class="sol-st" style="background:#FFF8ED;color:#92400e;border:2px solid #FFE9B8">⏳ Solicitud enviada · Esperando que '+p.nm+' acepte</div>';
    ba.innerHTML='<p style="font-size:.74rem;color:var(--gr);text-align:center;padding:.38rem 0;font-weight:600">Chat y entrevista se habilitan cuando haya match 💙</p>';
  } else if(sol==='accepted'){
    sa.innerHTML='<div class="sol-st" style="background:rgba(52,211,153,.1);color:#065f46;border:2px solid rgba(52,211,153,.22)">✅ Match confirmado! Ya podes chatear y reservar una entrevista 🎉</div>';
    ba.innerHTML='<div style="display:flex;gap:.45rem"><button class="btn bro bfull" id="bchat">💬 Abrir chat</button><button class="btn baz" id="bres" style="flex-shrink:0;padding:13px 15px;border-radius:13px;font-size:.78rem">📅 Entrevista</button></div>';
    setTimeout(function(){
      var bc=document.getElementById('bchat');var br=document.getElementById('bres');
      if(bc)bc.onclick=function(){cerrar('ov-perfil');abrirChat(profActual)};
      if(br)br.onclick=function(){abrirReserva()};
    },0);
  } else {
    sa.innerHTML='';
    ba.innerHTML='<button class="btn bro bfull" id="bsol">Quiero contactar a este profesional 💙</button>';
    setTimeout(function(){var bs=document.getElementById('bsol');if(bs)bs.onclick=solicitarContacto;},0);
  }
}

async function generarIA(p){
  try{
    var r=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:180,system:'Sos parte del equipo de Club Juntos Equipo de Salud. Escribis comentarios calidos sobre por que un profesional puede ser bueno para una familia. El club trabaja con todo tipo de discapacidades, no solo autismo. Espanol argentino, cercano. Max 60 palabras. Parrafo corrido.',messages:[{role:'user',content:'Familia busca: "'+(busqTxt||'profesional para acompanar a persona con discapacidad en Mar del Plata')+'". Profesional: '+p.nm+', '+p.tt+'. Trabaja con: '+p.discs.join(', ')+'. Zona: '+p.zona.join(', ')+'. Disponibilidad: '+p.turno+'. Escribe un comentario calido.'}]})});
    var d=await r.json();document.getElementById('mia').textContent=d.content[0].text;
  }catch(e){document.getElementById('mia').textContent=p.nm+' es un profesional verificado por Club Juntos con experiencia en acompanamiento de personas con discapacidad. Puede ser una muy buena opcion para tu familia 💙';}
}

function solicitarContacto(){
  if(!profActual)return;
  solicitudes[profActual.id]='pending';actualizarBotones(profActual);
  toast('Solicitud enviada a '+profActual.nm+' 💙 Te avisamos cuando acepte');
  var pid=profActual.id;
  setTimeout(function(){
    solicitudes[pid]='accepted';
    var pnm=PROFS.find(function(p){return p.id===pid}).nm;
    toast(pnm+' acepto tu solicitud! Ya podes chatear y reservar 🎉');
    if(document.getElementById('ov-perfil').classList.contains('on')&&profActual&&profActual.id===pid)actualizarBotones(profActual);
  },3000);
}

function abrirChat(p){
  var av=document.getElementById('chat-av');av.textContent=p.ini;av.style.background=p.bg;av.style.color=p.col;
  document.getElementById('chat-nm').textContent=p.nm;chatMsgs=MSGS.slice();renderChat();
  document.getElementById('ov-chat').classList.add('on');
}

function renderChat(){
  var c=document.getElementById('chmsgs');
  c.innerHTML=chatMsgs.map(function(m){return '<div class="msg '+(m.yo?'yo':'otro')+'">'+m.txt+'<div class="mtime">'+m.t+'</div></div>'}).join('');
  c.scrollTop=c.scrollHeight;
}

function enviarMsg(){
  var inp=document.getElementById('chin');var txt=inp.value.trim();if(!txt)return;
  var now=new Date();var t=now.getHours()+':'+String(now.getMinutes()).padStart(2,'0');
  chatMsgs.push({yo:true,txt:txt,t:t});inp.value='';renderChat();
  var hist=chatMsgs.slice(-6).map(function(m){return{role:m.yo?'user':'assistant',content:m.txt}});
  setTimeout(async function(){
    try{
      var r=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:120,system:'Sos '+(profActual?profActual.nm:'un profesional de salud')+', '+(profActual?profActual.tt:'profesional')+' en Mar del Plata. Respondes mensajes de familias dentro de Club Juntos Equipo de Salud. El club trabaja con todo tipo de discapacidades. Tono calido, cercano y profesional. Respuestas cortas (1-2 oraciones). Nunca compartas datos de contacto externos. Espanol argentino con emojis ocasionales.',messages:hist})});
      var d=await r.json();var n2=new Date();var t2=n2.getHours()+':'+String(n2.getMinutes()).padStart(2,'0');
      chatMsgs.push({yo:false,txt:d.content[0].text,t:t2});renderChat();
    }catch(e){chatMsgs.push({yo:false,txt:'Si, podemos coordinar por aca 😊 Que dias te quedan mejor?',t:new Date().getHours()+':'+String(new Date().getMinutes()).padStart(2,'0')});renderChat();}
  },1200);
}

function enterMsg(e){if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();enviarMsg()}}
function reportar(){toast('Reporte enviado al equipo de Club Juntos 🙏');cerrar('ov-chat')}

function abrirReserva(){
  if(!profActual)return;
  bkTipo=null;bkFecha=null;bkHora=null;
  document.getElementById('bk-sub').textContent='con '+profActual.nm;
  document.getElementById('tc-v').classList.remove('sel');document.getElementById('tc-p').classList.remove('sel');
  document.getElementById('sinfo').style.display='none';document.getElementById('btnp2').disabled=true;
  calY=new Date().getFullYear();calM=new Date().getMonth();
  irPaso(1);renderCal();document.getElementById('ov-reserva').classList.add('on');
}

function selTipo(tipo){
  bkTipo=tipo;document.getElementById('tc-v').classList.toggle('sel',tipo==='virtual');document.getElementById('tc-p').classList.toggle('sel',tipo==='presencial');
  document.getElementById('sinfo').style.display=tipo==='presencial'?'block':'none';document.getElementById('btnp2').disabled=false;
}

function irPaso(n){
  for(var i=1;i<=5;i++){var bs=document.getElementById('bs'+i);if(bs)bs.classList.toggle('on',i===n)}
  for(var i=1;i<=4;i++){
    var sd=document.getElementById('sd'+i);if(!sd)continue;
    sd.className=i<n?'sdot done':i===n?'sdot act':'sdot pend';
    var sl=document.getElementById('sl'+i);if(sl)sl.classList.toggle('done',i<n);
  }
  if(n===3)renderSlots();if(n===4)rellenarConfirm();
}

function renderCal(){
  document.getElementById('cal-tit').textContent=MESES[calM]+' '+calY;
  var hoy=new Date();hoy.setHours(0,0,0,0);var p=new Date(calY,calM,1),u=new Date(calY,calM+1,0);
  var html=DIAS_S.map(function(d){return '<div class="cdhd">'+d+'</div>'}).join('');
  for(var i=0;i<p.getDay();i++)html+='<div></div>';
  for(var d=1;d<=u.getDate();d++){
    var f=new Date(calY,calM,d),dow=f.getDay();
    var key=calY+'-'+String(calM+1).padStart(2,'0')+'-'+String(d).padStart(2,'0');
    var dis=f<hoy||dow===0||dow===6,sel=bkFecha===key,esHoy=f.getTime()===hoy.getTime();
    html+=dis?'<div class="cday dis">'+d+'</div>':'<div class="cday avail'+(sel?' sel':'')+(esHoy?' today':'')+'" onclick="selFecha(\''+key+'\')">'+d+'</div>';
  }
  document.getElementById('calgrid').innerHTML=html;
}

function cambiarMes(dir){calM+=dir;if(calM>11){calM=0;calY++}if(calM<0){calM=11;calY--}renderCal()}
function selFecha(key){bkFecha=key;bkHora=null;renderCal();document.getElementById('btnp3').disabled=false}

function renderSlots(){
  if(!bkFecha)return;
  var pts=bkFecha.split('-'),f=new Date(parseInt(pts[0]),parseInt(pts[1])-1,parseInt(pts[2]));
  document.getElementById('fechalbl').textContent=DIAS_N[f.getDay()]+' '+f.getDate()+' de '+MESES_MIN[f.getMonth()];
  document.getElementById('hslots').innerHTML=FRANJAS.map(function(h){
    var ocup=OCUP.indexOf(h)>=0,sel=bkHora===h;
    if(ocup)return '<div class="hslot ocup"><s>'+h+'</s><br><span style="font-size:.62rem">Ocupado</span></div>';
    return '<div class="hslot'+(sel?' sel':'')+'" onclick="selHora(\''+h+'\')">'+h+'</div>';
  }).join('');
}

function selHora(h){bkHora=h;renderSlots();document.getElementById('btnp4').disabled=false}

function rellenarConfirm(){
  if(!profActual||!bkFecha||!bkHora||!bkTipo)return;
  document.getElementById('cf-at').textContent=profActual.nm;
  document.getElementById('cf-tipo').textContent=bkTipo==='virtual'?'Videollamada':'Presencial en Club Juntos';
  var pts=bkFecha.split('-'),f=new Date(parseInt(pts[0]),parseInt(pts[1])-1,parseInt(pts[2]));
  document.getElementById('cf-fecha').textContent=f.getDate()+' de '+MESES_MIN[f.getMonth()]+' '+calY;
  document.getElementById('cf-hora').textContent=bkHora+' hs';
  document.getElementById('cf-sede').style.display=bkTipo==='presencial'?'flex':'none';
}

function confirmarReserva(){
  var nm=document.getElementById('res-nm').value.trim(),em=document.getElementById('res-em').value.trim();
  if(!nm||!em){toast('Completa tu nombre y email 😊');return}
  document.getElementById('conf-at').textContent=profActual?profActual.nm:'—';
  var pts=bkFecha.split('-'),f=new Date(parseInt(pts[0]),parseInt(pts[1])-1,parseInt(pts[2]));
  document.getElementById('conf-fecha').textContent=f.getDate()+' de '+MESES_MIN[f.getMonth()]+' '+calY;
  document.getElementById('conf-hora').textContent=bkHora+' hs';
  document.getElementById('conf-tipo').textContent=bkTipo==='virtual'?'Videollamada':'Presencial en Club Juntos';
  irPaso(5);
}

function adminTab(tab,btn){
  document.querySelectorAll('.atab').forEach(function(t){t.classList.remove('on')});
  document.querySelectorAll('.asec').forEach(function(s){s.classList.remove('on')});
  btn.classList.add('on');document.getElementById('as-'+tab).classList.add('on');
}

function verChatAdmin(fam,prof,ini,col){
  var av=document.getElementById('adchat-av');av.textContent=ini;av.style.background='var(--tus)';av.style.color=col;
  document.getElementById('adchat-nm').textContent=fam+' — '+prof;
  document.getElementById('admsgs').innerHTML=MSGS.map(function(m){
    return '<div class="msg '+(m.yo?'yo':'otro')+'"><div style="font-size:.58rem;opacity:.4;margin-bottom:1px">'+(m.yo?fam:prof)+'</div>'+m.txt+'<div class="mtime">'+m.t+'</div></div>';
  }).join('');
  setTimeout(function(){document.getElementById('admsgs').scrollTop=9999},50);
  document.getElementById('ov-adchat').classList.add('on');
}

function aprobar(btn){
  var tr=btn.closest('tr');
  tr.querySelector('td:nth-child(3)').innerHTML='<span class="spill sp-ok">✓ Activo</span>';
  tr.querySelector('td:nth-child(4)').innerHTML='<span class="spill sp-ok">✓ OK</span>';
  btn.closest('.actb').innerHTML='<button class="btn bout" style="font-size:.66rem;padding:3px 7px">Ver CV</button><button class="btn berr" style="font-size:.66rem;padding:3px 7px" onclick="toast(\'Suspendido\')">Suspender</button>';
  toast('Profesional aprobado y publicado 🎉');
}

function setVista(v,btn){
  document.querySelectorAll('.vista').forEach(function(x){x.classList.remove('on')});
  document.querySelectorAll('.np').forEach(function(x){x.classList.remove('on')});
  document.getElementById('v-'+v).classList.add('on');btn.classList.add('on');
}

function cerrar(id,e){if(!e||e.target===document.getElementById(id))document.getElementById(id).classList.remove('on')}

function simFoto(){
  document.getElementById('foto-badge').style.display='inline-flex';
  document.querySelector('.foto-ico').textContent='✅';
  document.querySelector('.foto-txt').textContent='Foto subida';
  toast('Foto subida. Pendiente de aprobacion por Club Juntos 📸');
}
function simUpload(){
  document.getElementById('upzone').style.display='none';
  document.getElementById('updone').style.display='flex';
  toast('Titulo subido correctamente 📄 Lo revisamos en breve');
}

function toast(msg){
  var t=document.getElementById('toast-el');t.textContent=msg;t.classList.add('on');
  setTimeout(function(){t.classList.remove('on')},3500);
}

render(PROFS);
</script>
</body>

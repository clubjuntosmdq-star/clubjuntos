  document.getElementById('mexp').innerHTML=p.exp.map(function(e){return '<span class="mtag mro">'+e+'</span>'}).join('');
  document.getElementById('mzona').innerHTML=p.zona.map(function(z){return '<span class="mtag mam">📍 '+z+'</span>'}).join('');

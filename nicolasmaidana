async function buscarIA(){
  var txt=document.getElementById('txtsearch').value.trim();
  if(!txt){toast('Contanos que necesitas primero 😊');return}
  busqTxt=txt;
  var btn=document.getElementById('btnIA');btn.disabled=true;btn.innerHTML='<span class="sp"></span> Buscando...';
  var box=document.getElementById('iares');box.classList.add('on');
  document.getElementById('iatxt').innerHTML='<span class="sp spd"></span> Analizando...';
  try{
    var r=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:400,system:'Sos parte del equipo de Club Juntos Equipo de Salud, una plataforma calida de Mar del Plata que conecta familias con profesionales de salud para personas con todo tipo de discapacidades (no solo autismo). Hablas como alguien del equipo: cercano, humano, esperanzador. Responde en espanol argentino. Maximo 80 palabras. Parrafo corrido.',messages:[{role:'user',content:txt}]})});
    var d=await r.json();
    document.getElementById('iatxt').textContent=d.content[0].text;
    document.getElementById('iast').textContent='· Listo';
  }catch(e){document.getElementById('iatxt').textContent='Entendemos lo que buscas. Te recomendamos ver los perfiles disponibles y usar los filtros para encontrar al profesional ideal 💙';}
  btn.disabled=false;btn.innerHTML='✨ Buscar';
}


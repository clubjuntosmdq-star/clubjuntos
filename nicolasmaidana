<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Club Juntos — Equipo de Salud</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
:root{--az:#1B2A6B;--tu:#2DC8C8;--am:#F5C842;--ro:#E8538F;--cr:#FDF9F3;--bl:#FFFFFF;--gr:#9B9B9B;--bo:#EDE9E0;--tus:#E8F9F9;--ros:#FDE8F2;--ams:#FEF9E7;--azs:#EEF0F8;--ok:#34d399}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
body{font-family:'Nunito',sans-serif;background:var(--cr);color:#2D2D2D;min-height:100vh;overflow-x:hidden}

/* BIENVENIDA */
#welcome{position:fixed;inset:0;background:var(--cr);z-index:200;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:2rem;text-align:center;transition:opacity .6s,transform .6s}
#welcome.out{opacity:0;transform:scale(.97);pointer-events:none}
.wlogo{display:flex;align-items:center;gap:8px;justify-content:center;margin-bottom:1.8rem}
.wlogo-ic{width:42px;height:42px;background:var(--az);border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.2rem}
.wlogo-t{font-size:.95rem;font-weight:800;color:var(--az);line-height:1.2;text-align:left}
.wlogo-t span{color:var(--tu);display:block;font-size:.78rem;font-weight:700}
.wtitle{font-size:clamp(1.7rem,6vw,2.4rem);font-weight:900;color:var(--az);line-height:1.15;margin-bottom:.65rem}
.wtitle em{color:var(--tu);font-style:normal}
.wsub{font-size:.88rem;color:var(--gr);line-height:1.7;max-width:300px;margin:0 auto 2rem;font-weight:500}
.wcards{display:grid;grid-template-columns:1fr 1fr;gap:.7rem;width:100%;max-width:330px}
.wcard{background:var(--bl);border:2px solid var(--bo);border-radius:22px;padding:1.3rem 1rem;cursor:pointer;transition:all .2s;text-align:center;box-shadow:0 2px 12px rgba(0,0,0,.04)}
.wcard:hover{border-color:var(--tu);transform:translateY(-3px);box-shadow:0 8px 24px rgba(45,200,200,.14)}
.wcard .wico{font-size:2rem;margin-bottom:.55rem;display:block}
.wcard h3{font-size:.86rem;font-weight:800;color:var(--az);margin-bottom:.22rem}
.wcard p{font-size:.7rem;color:var(--gr);line-height:1.4;font-weight:500}

/* APP */
#app{display:none;min-height:100vh;flex-direction:column}
#app.on{display:flex}

/* NAV */
nav{background:var(--bl);height:56px;display:flex;align-items:center;justify-content:space-between;padding:0 1rem;position:sticky;top:0;z-index:50;border-bottom:1.5px solid var(--bo);box-shadow:0 2px 10px rgba(0,0,0,.04)}
.nlogo{display:flex;align-items:center;gap:6px}
.nlogo-ic{width:30px;height:30px;background:var(--az);border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:.85rem}
.nlogo-t{font-size:.84rem;font-weight:800;color:var(--az);line-height:1.15}
.nlogo-t span{color:var(--tu);display:block;font-size:.68rem;font-weight:700}
.npills{display:flex;gap:2px;background:var(--cr);border-radius:10px;padding:3px}
.np{padding:4px 9px;border-radius:8px;font-size:.7rem;font-weight:800;cursor:pointer;color:var(--gr);border:none;background:transparent;transition:.15s;font-family:'Nunito',sans-serif}
.np.on{background:var(--az);color:white}
.nbell{position:relative;cursor:pointer;width:34px;height:34px;background:var(--cr);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1rem}
.nbell-dot{position:absolute;top:6px;right:6px;width:7px;height:7px;background:var(--ro);border-radius:50%;border:2px solid var(--bl)}

/* VISTAS */
.vista{display:none}.vista.on{display:block}

/* HERO */
.hero{background:var(--bl);padding:1.8rem 1.2rem 1.2rem;border-bottom:1.5px solid var(--bo)}
.hero-inner{max-width:560px;margin:0 auto}
.hero-chip{display:inline-flex;align-items:center;gap:5px;background:var(--tus);color:var(--tu);padding:4px 12px;border-radius:20px;font-size:.7rem;font-weight:800;letter-spacing:.03em;margin-bottom:.85rem}
.hero h1{font-size:clamp(1.45rem,5vw,2.1rem);font-weight:900;color:var(--az);line-height:1.2;margin-bottom:.6rem}
.hero h1 em{color:var(--tu);font-style:normal}
.hero-sub{font-size:.86rem;color:var(--gr);line-height:1.7;max-width:400px;margin-bottom:1.3rem;font-weight:500}
.sbox{background:var(--cr);border:2px solid var(--bo);border-radius:18px;padding:.95rem;transition:.18s}
.sbox:focus-within{border-color:var(--tu);background:var(--bl)}
.sbox textarea{width:100%;background:transparent;border:none;outline:none;color:#2D2D2D;font-family:'Nunito',sans-serif;font-size:.86rem;resize:none;min-height:50px;font-weight:500}
.sbox textarea::placeholder{color:#C5C0B8}
.sbox-ft{display:flex;align-items:center;justify-content:space-between;margin-top:.55rem;padding-top:.55rem;border-top:1.5px solid var(--bo)}
.sbox-hint{font-size:.67rem;color:#C5C0B8;font-weight:600}
.btn-ia{background:var(--az);color:white;border:none;border-radius:12px;padding:9px 16px;font-family:'Nunito',sans-serif;font-weight:800;font-size:.76rem;cursor:pointer;display:flex;align-items:center;gap:5px;transition:.15s}
.btn-ia:hover{background:var(--tu)}.btn-ia:disabled{opacity:.5;cursor:not-allowed}

/* FILTROS */
.filtros-wrap{background:var(--bl);border-bottom:1.5px solid var(--bo);padding:.75rem 1rem}
.filtros-label{font-size:.65rem;font-weight:800;color:var(--gr);text-transform:uppercase;letter-spacing:.06em;margin-bottom:.45rem}
.filtros-row{display:flex;gap:.32rem;overflow-x:auto;scrollbar-width:none;padding-bottom:2px;margin-bottom:.5rem}
.filtros-row:last-child{margin-bottom:0}
.filtros-row::-webkit-scrollbar{display:none}
.ftipo{padding:5px 12px;border-radius:20px;border:2px solid var(--bo);font-size:.72rem;font-weight:800;cursor:pointer;transition:.14s;background:transparent;color:#555;white-space:nowrap;flex-shrink:0;font-family:'Nunito',sans-serif}
.ftipo.on{background:var(--az);color:white;border-color:var(--az)}
.fchip{padding:5px 12px;border-radius:20px;border:2px solid var(--bo);font-size:.72rem;font-weight:700;cursor:pointer;transition:.14s;background:transparent;color:#555;white-space:nowrap;flex-shrink:0;font-family:'Nunito',sans-serif}
.fchip.on{background:var(--tus);color:var(--tu);border-color:var(--tu)}

/* IA RESULT */
.iares{margin:.85rem 1rem;background:var(--tus);border:1.5px solid rgba(45,200,200,.22);border-radius:18px;padding:.9rem 1rem;display:none}
.iares.on{display:block}
.iares-hd{font-size:.68rem;font-weight:800;color:var(--tu);text-transform:uppercase;letter-spacing:.05em;margin-bottom:.38rem}
.iares p{font-size:.85rem;line-height:1.7;color:#2D2D2D;font-weight:500}

/* GRID */
.gwrap{padding:1rem;max-width:980px;margin:0 auto}
.ghd{display:flex;align-items:center;justify-content:space-between;margin-bottom:.85rem}
.ghd h2{font-size:.92rem;font-weight:800;color:var(--az)}
.ghd span{font-size:.74rem;color:var(--gr);font-weight:600}
.pgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(255px,1fr));gap:.8rem}

/* CARD */
.pcard{background:var(--bl);border:2px solid var(--bo);border-radius:22px;overflow:hidden;transition:all .2s;cursor:pointer;position:relative}
.pcard:hover{border-color:var(--tu);box-shadow:0 8px 28px rgba(45,200,200,.12);transform:translateY(-3px)}
.pcard-verif{position:absolute;top:10px;right:10px;background:var(--tus);color:var(--tu);font-size:.62rem;font-weight:800;padding:2px 8px;border-radius:20px}
.pcard-hd{padding:.9rem .9rem .65rem;display:flex;gap:.65rem;align-items:flex-start}
.pav-wrap{position:relative;flex-shrink:0}
.pav{width:52px;height:52px;border-radius:14px;object-fit:cover;display:block}
.pav-placeholder{width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;font-weight:900;flex-shrink:0}
.pci h3{font-size:.86rem;font-weight:800;color:var(--az)}
.psub{font-size:.69rem;color:var(--gr);margin:2px 0 5px;font-weight:600}
.ptags{display:flex;flex-wrap:wrap;gap:3px}
.ptag{font-size:.61rem;padding:2px 6px;border-radius:8px;font-weight:800}
.ptag-tipo{background:var(--azs);color:var(--az)}
.ptag-disc{background:var(--ros);color:var(--ro)}
.ptag-zona{background:var(--ams);color:#8a6000}
.pcard-body{padding:0 .9rem .9rem}
.pdiv{height:1.5px;background:var(--bo);margin-bottom:.6rem}
.prow{display:flex;align-items:center;gap:6px;font-size:.76rem;color:#666;margin-bottom:3px;font-weight:600}
.pcard-ft{padding:.65rem .9rem;background:var(--cr);display:flex;align-items:center;justify-content:space-between;border-top:1.5px solid var(--bo)}
.pdisp{display:flex;align-items:center;gap:4px;font-size:.7rem;font-weight:800}
.pdot{width:7px;height:7px;border-radius:50%}

/* BOTONES */
.btn{border:none;border-radius:12px;padding:8px 14px;font-size:.76rem;font-weight:800;cursor:pointer;transition:.15s;font-family:'Nunito',sans-serif}
.baz{background:var(--az);color:white}.baz:hover{background:#253a99}
.bro{background:var(--ro);color:white}.bro:hover{background:#d4477f}
.btu{background:var(--tu);color:white}
.bam{background:var(--am);color:var(--az)}
.bok{background:var(--ok);color:white}
.berr{background:#f87171;color:white}
.bout{background:transparent;border:2px solid var(--bo);color:#555}.bout:hover{border-color:var(--az);color:var(--az)}
.bfull{width:100%;padding:14px;font-size:.9rem;border-radius:16px}

/* OVERLAY */
.ov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.35);z-index:100;backdrop-filter:blur(6px);align-items:center;justify-content:center;padding:1rem}
.ov.on{display:flex}

/* MODAL PERFIL / CV */
.modal{background:var(--cr);border-radius:26px;max-width:520px;width:100%;max-height:92vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,.15)}
.mhd{background:var(--az);padding:1.2rem;border-radius:26px 26px 0 0;display:flex;align-items:center;gap:.85rem}
.mav-lg{width:64px;height:64px;border-radius:18px;object-fit:cover;flex-shrink:0}
.mav-lg-ph{width:64px;height:64px;border-radius:18px;display:flex;align-items:center;justify-content:center;font-size:1.5rem;font-weight:900;flex-shrink:0}
.mname h2{font-size:1.05rem;font-weight:900;color:white}
.mname p{color:rgba(255,255,255,.5);font-size:.74rem;margin-top:2px;font-weight:600}
.mtipo-badge{display:inline-block;background:rgba(255,255,255,.15);color:white;font-size:.66rem;font-weight:800;padding:2px 9px;border-radius:20px;margin-top:5px}
.mclose{margin-left:auto;background:rgba(255,255,255,.12);border:none;color:white;width:30px;height:30px;border-radius:10px;cursor:pointer;font-size:.88rem;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.mbody{padding:1.2rem}
.mtabs{display:flex;gap:3px;background:var(--bo);border-radius:12px;padding:3px;margin-bottom:1.1rem}
.mtab{flex:1;padding:7px;border-radius:9px;font-size:.76rem;font-weight:800;cursor:pointer;border:none;background:transparent;color:var(--gr);transition:.15s;font-family:'Nunito',sans-serif;text-align:center}
.mtab.on{background:white;color:var(--az);box-shadow:0 1px 5px rgba(0,0,0,.07)}
.mpanel{display:none}.mpanel.on{display:block}
.msec{margin-bottom:1.1rem}
.msect{font-size:.66rem;font-weight:800;text-transform:uppercase;letter-spacing:.08em;color:var(--tu);margin-bottom:.42rem}
.mtags{display:flex;flex-wrap:wrap;gap:4px}
.mtag{padding:4px 10px;border-radius:10px;font-size:.76rem;font-weight:700}
.maz{background:var(--azs);color:var(--az)}
.mro{background:var(--ros);color:var(--ro)}
.mam{background:var(--ams);color:#8a6000}
.mtu{background:var(--tus);color:#0e7490}
.hgrid{display:grid;grid-template-columns:repeat(7,1fr);gap:4px;text-align:center}
.hdia{font-size:.65rem;font-weight:800;padding:5px 2px;border-radius:8px}
.hdia.on{background:var(--tu);color:white}.hdia.off{background:var(--bo);color:var(--gr)}
.iabox{background:var(--tus);border:1.5px solid rgba(45,200,200,.2);border-radius:16px;padding:.9rem;margin-bottom:1rem}
.ialbl{font-size:.66rem;font-weight:800;color:var(--tu);text-transform:uppercase;letter-spacing:.05em;margin-bottom:.38rem}
.iabox p{font-size:.83rem;line-height:1.7;color:#2D2D2D;font-weight:500}
.sol-st{padding:.7rem .9rem;border-radius:14px;margin-bottom:.85rem;font-size:.8rem;font-weight:700;display:flex;align-items:center;gap:7px}

/* CV PANEL */
.cv-section{background:var(--bl);border:2px solid var(--bo);border-radius:16px;padding:1rem;margin-bottom:.8rem}
.cv-section h4{font-size:.8rem;font-weight:800;color:var(--az);margin-bottom:.6rem;display:flex;align-items:center;gap:6px}
.cv-item{padding:.5rem 0;border-bottom:1px solid var(--bo);font-size:.82rem;font-weight:500;color:#444;line-height:1.6}
.cv-item:last-child{border:none;padding-bottom:0}
.cv-item strong{font-weight:800;color:var(--az);display:block;font-size:.84rem}
.cv-item span{font-size:.74rem;color:var(--gr);font-weight:600}
.cv-bio{font-size:.84rem;line-height:1.75;color:#444;font-weight:500;background:var(--bl);border:2px solid var(--bo);border-radius:16px;padding:1rem}
.cv-os-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:5px}
.cv-os-tag{background:var(--azs);color:var(--az);font-size:.72rem;font-weight:700;padding:4px 10px;border-radius:9px;text-align:center}

/* SPINNER */
.sp{display:inline-block;width:11px;height:11px;border:2.5px solid rgba(255,255,255,.3);border-top-color:white;border-radius:50%;animation:spin .65s linear infinite;vertical-align:middle}
.spd{border-color:rgba(45,200,200,.2);border-top-color:var(--tu)}
@keyframes spin{to{transform:rotate(360deg)}}

/* CHAT */
.chov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.35);z-index:150;backdrop-filter:blur(6px);align-items:flex-end;justify-content:center}
.chov.on{display:flex}
.chmodal{background:var(--bl);width:100%;max-width:440px;height:80vh;border-radius:24px 24px 0 0;display:flex;flex-direction:column;overflow:hidden;box-shadow:0 -8px 40px rgba(0,0,0,.12)}
.chhd{background:var(--az);padding:.88rem 1rem;display:flex;align-items:center;gap:.65rem;flex-shrink:0}
.chav{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:.9rem;font-weight:900;flex-shrink:0}
.chinfo h3{font-size:.86rem;font-weight:800;color:white}
.chinfo p{font-size:.65rem;color:rgba(255,255,255,.42);font-weight:600}
.chwarn{background:#FFF8ED;border-bottom:1.5px solid #FFE9B8;padding:.5rem 1rem;font-size:.68rem;color:#8a6000;display:flex;align-items:center;gap:5px;flex-shrink:0;font-weight:700}
.chrep{margin-left:auto;background:#FEE2E2;color:#dc2626;border:none;padding:2px 8px;border-radius:7px;font-size:.63rem;font-weight:800;cursor:pointer;font-family:'Nunito',sans-serif}
.chmsgs{flex:1;overflow-y:auto;padding:.88rem;display:flex;flex-direction:column;gap:.52rem;background:#F9F9F9}
.msg{max-width:80%;padding:.62rem .82rem;border-radius:16px;font-size:.82rem;line-height:1.55;word-break:break-word;font-weight:500}
.msg.yo{align-self:flex-end;background:var(--az);color:white;border-radius:16px 16px 4px 16px}
.msg.otro{align-self:flex-start;background:white;color:#2D2D2D;border:1.5px solid var(--bo);border-radius:16px 16px 16px 4px}
.mtime{font-size:.58rem;opacity:.44;margin-top:2px;text-align:right;font-weight:600}
.chft{padding:.68rem .88rem;background:white;border-top:1.5px solid var(--bo);display:flex;gap:.48rem;align-items:flex-end;flex-shrink:0}
.chin{flex:1;border:2px solid var(--bo);border-radius:12px;padding:8px 11px;font-family:'Nunito',sans-serif;font-size:.84rem;resize:none;outline:none;max-height:90px;transition:.15s;font-weight:500}
.chin:focus{border-color:var(--tu)}
.chsend{background:var(--tu);border:none;width:36px;height:36px;border-radius:11px;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.chclose{background:rgba(255,255,255,.12);border:none;color:white;width:30px;height:30px;border-radius:9px;cursor:pointer;font-size:.85rem;display:flex;align-items:center;justify-content:center}

/* BOOKING */
.bkmodal{background:var(--cr);border-radius:26px;max-width:450px;width:100%;max-height:92vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,.15)}
.bkhd{background:var(--az);padding:1rem 1.2rem;border-radius:26px 26px 0 0;display:flex;align-items:center;justify-content:space-between}
.bkhd h2{font-size:.93rem;font-weight:900;color:white}
.bkhd p{font-size:.7rem;color:rgba(255,255,255,.42);margin-top:1px;font-weight:600}
.bkbody{padding:1.1rem}
.bkstep{display:none}.bkstep.on{display:block}
.stepind{display:flex;gap:4px;margin-bottom:1.1rem;align-items:center}
.sdot{width:25px;height:25px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.68rem;font-weight:900;flex-shrink:0;transition:.28s}
.sdot.done{background:var(--tu);color:white}.sdot.act{background:var(--az);color:white}.sdot.pend{background:var(--bo);color:var(--gr)}
.sline{flex:1;height:2px;background:var(--bo);border-radius:2px;transition:.28s}.sline.done{background:var(--tu)}
.tgrid{display:grid;grid-template-columns:1fr 1fr;gap:.65rem;margin-bottom:1rem}
.tcard{border:2px solid var(--bo);border-radius:18px;padding:.95rem;text-align:center;cursor:pointer;transition:.18s;background:var(--bl)}
.tcard:hover{border-color:var(--tu)}.tcard.sel{border-color:var(--tu);background:var(--tus)}
.tcard .ico{font-size:1.75rem;margin-bottom:.38rem}
.tcard h4{font-size:.82rem;font-weight:800;color:var(--az);margin-bottom:.18rem}
.tcard p{font-size:.68rem;color:var(--gr);line-height:1.4;font-weight:500}
.sinfo{background:#FFF8ED;border:1.5px solid #FFE9B8;border-radius:12px;padding:.72rem;font-size:.78rem;color:#8a6000;margin-bottom:.88rem;line-height:1.5;font-weight:600;display:none}
.calnav{display:flex;align-items:center;justify-content:space-between;margin-bottom:.6rem}
.calnav h3{font-size:.88rem;font-weight:800;color:var(--az)}
.calnav button{background:var(--bl);border:2px solid var(--bo);border-radius:9px;width:27px;height:27px;cursor:pointer;font-size:.82rem;transition:.14s;font-family:'Nunito',sans-serif}
.calnav button:hover{border-color:var(--tu)}
.calgrid{display:grid;grid-template-columns:repeat(7,1fr);gap:2px;margin-bottom:.8rem}
.cdhd{text-align:center;font-size:.61rem;font-weight:800;color:var(--gr);padding:3px 0;text-transform:uppercase}
.cday{text-align:center;padding:5px 2px;border-radius:9px;font-size:.76rem;cursor:pointer;border:2px solid transparent;transition:.14s;min-height:29px;display:flex;align-items:center;justify-content:center;font-weight:700}
.cday.avail:hover{border-color:var(--tu);background:var(--tus)}.cday.sel{background:var(--tu);color:white;border-color:var(--tu)}.cday.dis{color:#DDD;cursor:default;pointer-events:none}.cday.today{color:var(--az)}
.hslots{display:grid;grid-template-columns:repeat(3,1fr);gap:.4rem;margin-bottom:1rem}
.hslot{border:2px solid var(--bo);border-radius:12px;padding:.52rem;text-align:center;cursor:pointer;transition:.14s;font-size:.78rem;font-weight:700;background:var(--bl)}
.hslot:hover{border-color:var(--tu);background:var(--tus)}.hslot.sel{background:var(--az);color:white;border-color:var(--az)}.hslot.ocup{background:#F5F5F5;color:#CCC;cursor:default;text-decoration:line-through;font-size:.7rem}
.cfcard{background:var(--bl);border:2px solid var(--bo);border-radius:16px;padding:.95rem;margin-bottom:.95rem}
.cfrow{display:flex;align-items:flex-start;gap:8px;font-size:.8rem;padding:4px 0}
.cfl{color:var(--gr);width:80px;flex-shrink:0;font-size:.74rem;font-weight:700}
.cfv{font-weight:800;color:var(--az)}
.bknav{display:flex;gap:.5rem;margin-top:.8rem}
.confirm-screen{text-align:center;padding:1rem .5rem}
.confirm-ico{font-size:3.2rem;margin-bottom:.75rem}
.confirm-screen h3{font-size:1.15rem;font-weight:900;color:var(--az);margin-bottom:.38rem}
.confirm-screen p{font-size:.84rem;color:var(--gr);line-height:1.7;margin-bottom:1.1rem;font-weight:500}
.confirm-detail{background:var(--tus);border:1.5px solid rgba(45,200,200,.2);border-radius:16px;padding:.92rem;margin-bottom:1rem;text-align:left}

/* FORM */
